{
  "name": "@super-memory/api",
  "version": "0.1.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/server.ts",
    "db:generate": "prisma generate",
    "db:prepare": "echo 'CREATE EXTENSION IF NOT EXISTS vector;' | prisma db execute --stdin --url \"$DATABASE_URL\"",
    "db:migrate": "prisma db push --accept-data-loss",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/sensible": "^6.0.1",
    "@prisma/client": "^6.7.0",
    "@super-memory/shared": "0.1.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify-plugin": "^5.0.1",
    "fastify": "^5.3.0",
    "openai": "^4.98.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^6.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
