NODE_ENV=development
API_PORT=4000
WEB_PORT=5173
DATABASE_URL=postgresql://supermemory:supermemory@postgres:5432/supermemory
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d
API_KEY_PREFIX=smem_
EMBEDDINGS_ENABLED=true
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
CORS_ORIGIN=http://localhost:5173
REDIS_URL=redis://redis:6379
VITE_API_URL=http://localhost:4000/api/v1

SUPER_MEMORY_API_URL=http://api:4000
SUPER_MEMORY_API_KEY=
MCP_SERVER_NAME=super-memory
MCP_WRITE_MODE=suggest
MCP_DEFAULT_LIMIT=8
MCP_MAX_LIMIT=20
MCP_ENABLE_RESOURCES=true
MCP_ENABLE_PROMPTS=true
MCP_REDACT_SECRETS=true

SMART_MEMORY_ENABLED=true
SMART_MEMORY_AI_ENABLED=false
DUPLICATE_SIMILARITY_THRESHOLD=0.90
POSSIBLE_DUPLICATE_THRESHOLD=0.85
MEMORY_LOW_QUALITY_THRESHOLD=0.40
SMART_MEMORY_AUTO_DELETE=false
SMART_MEMORY_AUTO_MERGE=false
SMART_MEMORY_REVIEW_REQUIRED=true
